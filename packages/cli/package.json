{
  "name": "@skillops/cli",
  "version": "0.1.0",
  "description": "Command-line interface for SkillOps.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mertyakdemir/skillops.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/mertyakdemir/skillops/issues"
  },
  "homepage": "https://github.com/mertyakdemir/skillops#readme",
  "keywords": [
    "ai",
    "agents",
    "instructions",
    "scanner",
    "cli"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "skillops": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "dist/index.js",
    "dist/index.js.map"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc -p tsconfig.json --noEmit",
    "skillops": "node ./dist/index.js"
  },
  "dependencies": {
    "@skillops/core": "workspace:*",
    "chalk": "^5.4.1",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
